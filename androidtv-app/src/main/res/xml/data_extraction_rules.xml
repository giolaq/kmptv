<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive data -->
        <exclude domain="sharedpref" path="sensitive_preferences.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- Include most app data -->
        <include domain="root" />
        <include domain="file" />
        <include domain="database" />
        <include domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
